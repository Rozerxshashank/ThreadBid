datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  buyer
  seller
  admin
}

enum KycStatus {
  pending
  submitted
  verified
  rejected
}

enum Condition {
  new_with_tags
  new_without_tags
  like_new
  used
}

enum ListingStatus {
  draft
  pending_review
  approved
  rejected
}

enum AuctionStatus {
  scheduled
  live
  ended
  settled
  cancelled
}

enum BidStatus {
  placed
  winning
  won
  outbid
  voided
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum FulfillmentStatus {
  awaiting_dispatch
  dispatched
  delivered
  returned
}

model User {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String         @unique @db.VarChar(255)
  passwordHash  String         @map("password_hash") @db.VarChar(255)
  role          Role
  isVerified    Boolean        @default(false) @map("is_verified")
  isSuspended   Boolean        @default(false) @map("is_suspended")
  kycStatus     KycStatus      @default(pending) @map("kyc_status")
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime       @default(now()) @map("updated_at") @db.Timestamptz

  sellerProfile SellerProfile?
  listings      Listing[]
  auctions      Auction[]
  bids          Bid[]
  ordersAsBuyer Order[]        @relation("BuyerOrders")
  ordersAsSeller Order[]       @relation("SellerOrders")

  @@map("users")
}

model SellerProfile {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String    @unique @map("user_id") @db.Uuid
  businessName   String    @map("business_name") @db.VarChar(255)
  gstin          String?   @db.VarChar(15)
  pan            String?   @db.VarChar(10)
  bankAccount    String?   @map("bank_account") // Stored as encrypted string or JSON
  isBrandPartner Boolean   @default(false) @map("is_brand_partner")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("seller_profiles")
}

model Listing {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sellerId    String        @map("seller_id") @db.Uuid
  title       String        @db.VarChar(255)
  description String?
  category    String?       @db.VarChar(100)
  brand       String?       @db.VarChar(100)
  lotSize     Int           @map("lot_size")
  condition   Condition?
  images      String[]      // Array of text
  status      ListingStatus @default(draft)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz

  user        User          @relation(fields: [sellerId], references: [id])
  auctions    Auction[]

  @@map("listings")
}

model Auction {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listingId    String        @map("listing_id") @db.Uuid
  sellerId     String        @map("seller_id") @db.Uuid
  startPrice   Decimal       @map("start_price") @db.Decimal(12, 2)
  reservePrice Decimal?      @map("reserve_price") @db.Decimal(12, 2)
  buyNowPrice  Decimal?      @map("buy_now_price") @db.Decimal(12, 2)
  currentBid   Decimal?      @map("current_bid") @db.Decimal(12, 2)
  bidIncrement Decimal       @map("bid_increment") @db.Decimal(10, 2)
  startTime    DateTime      @map("start_time") @db.Timestamptz
  endTime      DateTime      @map("end_time") @db.Timestamptz
  status       AuctionStatus @default(scheduled)
  winningBidId String?       @map("winning_bid_id") @db.Uuid
  totalBids    Int           @default(0) @map("total_bids")
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime      @default(now()) @map("updated_at") @db.Timestamptz

  listing      Listing       @relation(fields: [listingId], references: [id])
  seller       User          @relation(fields: [sellerId], references: [id])
  bids         Bid[]
  orders       Order[]

  @@map("auctions")
}

model Bid {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  auctionId   String    @map("auction_id") @db.Uuid
  bidderId    String    @map("bidder_id") @db.Uuid
  amount      Decimal   @db.Decimal(12, 2)
  status      BidStatus @default(placed)
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  placedAt    DateTime  @default(now()) @map("placed_at") @db.Timestamptz

  auction     Auction   @relation(fields: [auctionId], references: [id])
  bidder      User      @relation(fields: [bidderId], references: [id])

  @@index([auctionId, amount(sort: Desc)])
  @@map("bids")
}

model Order {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  auctionId         String             @map("auction_id") @db.Uuid
  buyerId           String             @map("buyer_id") @db.Uuid
  sellerId          String             @map("seller_id") @db.Uuid
  finalAmount       Decimal            @map("final_amount") @db.Decimal(12, 2)
  commissionRate    Decimal            @map("commission_rate") @db.Decimal(5, 4)
  commissionAmt     Decimal            @map("commission_amt") @db.Decimal(12, 2)
  sellerPayout      Decimal            @map("seller_payout") @db.Decimal(12, 2)
  paymentStatus     PaymentStatus      @default(pending) @map("payment_status")
  fulfillmentStatus FulfillmentStatus? @map("fulfillment_status")
  shippingAddress   String             @map("shipping_address") // JSON string stored as string or Json
  razorpayOrderId   String?            @map("razorpay_order_id") @db.VarChar(255)
  razorpayPaymentId String?            @map("razorpay_payment_id") @db.VarChar(255)
  paymentDeadline   DateTime           @map("payment_deadline") @db.Timestamptz
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime           @default(now()) @map("updated_at") @db.Timestamptz

  auction           Auction            @relation(fields: [auctionId], references: [id])
  buyer             User               @relation("BuyerOrders", fields: [buyerId], references: [id])
  seller            User               @relation("SellerOrders", fields: [sellerId], references: [id])

  @@map("orders")
}

model AuditLog {
  id         BigInt    @id @default(autoincrement())
  actorId    String?   @map("actor_id") @db.Uuid
  action     String    @db.VarChar(100)
  entityType String?   @map("entity_type") @db.VarChar(50)
  entityId   String?   @map("entity_id") @db.Uuid
  metadata   String?   // JSON stored as string
  ipAddress  String?   @map("ip_address")
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz

  @@map("audit_log")
}
